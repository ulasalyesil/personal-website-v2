{
  "root": true,
  "extends": [
    "next",
    "next/core-web-vitals"
  ],
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "warn",
    "react/self-closing-comp": "error",
    "react/jsx-curly-brace-presence": [
      "error",
      {
        "props": "never",
        "children": "never"
      }
    ]
  }
}